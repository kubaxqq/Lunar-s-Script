-- // Helper: set status message with color
local function setStatus(msg, color)
    StatusLabel.Text       = msg
    StatusLabel.TextColor3 = color
end

-- // Check Key Logic
CheckBtn.MouseButton1Click:Connect(function()
    local entered = TextBox.Text:match("^%s*(.-)%s*$")  -- trim whitespace
    if entered == "" then
        setStatus("⚠  Please enter a key first.", Color3.fromRGB(248, 113, 113))
        return
    end
    if entered == VALID_KEY then
        setStatus("✓  Valid key — loading script…", Color3.fromRGB(74, 222, 128))
        task.wait(0.8)
        -- Close GUI and remove blur
        Blur:Destroy()
        ScreenGui:Destroy()
        -- 🔧 PUT YOUR SCRIPT LOGIC HERE (runs after valid key)
    else
        setStatus("✗  Invalid key. Get one via the link.", Color3.fromRGB(248, 113, 113))
    end
end)

-- // Copy Link Logic
CopyBtn.MouseButton1Click:Connect(function()
    setToClipboard(KEY_LINK)   -- works in most executors
    CopyBtn.Text = "Copied!"
    setStatus("Link copied to clipboard!", Color3.fromRGB(168, 159, 247))
    task.wait(2)
    CopyBtn.Text = "Copy Link"
    setStatus("", Color3.fromRGB(200, 200, 215))
end)

